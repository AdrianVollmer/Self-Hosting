[Unit]
Description=Generate Caddyfile from Anchorage container definitions
Documentation=man:anchorage(7)
Before=caddy.service
PartOf=caddy.service

[Service]
Type=oneshot
EnvironmentFile=/etc/anchorage/anchorage.conf
EnvironmentFile=-/var/lib/anchorage/env.shared
ExecStart=/usr/lib/anchorage/gen-caddyfile.py
ExecStartPost=-/usr/bin/caddy reload

[Install]
WantedBy=caddy.service
